PORT=3001

DB_HOST=mysql-payment
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=payment_db
DB_PORT=3306

# Phải trùng với JWT_ACCESS_SECRET của Auth Service — Payment Service không phát hành token,
# chỉ XÁC THỰC chữ ký của Access Token do Auth Service ký (và token hệ thống do Order Service tự ký
# khi gọi nội bộ — xem order-service/src/utils/systemToken.js).
JWT_ACCESS_SECRET=change_me_access_secret

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=payment-service
KAFKA_CONSUMER_GROUP_ID=payment-service-group

# --- Cấu hình cổng thanh toán VNPay (môi trường sandbox) ---
# vnp_TmnCode + Hash Secret do VNPay cấp khi đăng ký tài khoản merchant sandbox tại
# https://sandbox.vnpayment.vn — đổi sang giá trị thật khi có tài khoản; giữ placeholder
# vẫn cho phép service build URL/ký số đúng thuật toán để kiểm thử nội bộ (chữ ký tự-nhất-quán).
VNPAY_TMN_CODE=change_me_tmn_code
VNPAY_HASH_SECRET=change_me_hash_secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# URL FE sẽ nhận khách quay về sau khi thanh toán (FE tự đọc query string để hiển thị, KHÔNG tự
# kết luận kết quả — kết quả chính thức chỉ được xác nhận qua IPN ở BE, đúng khuyến cáo của VNPay).
VNPAY_RETURN_URL=http://localhost:3000/checkout/payment-result
