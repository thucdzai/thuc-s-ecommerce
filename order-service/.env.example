PORT=3001

DB_HOST=mysql-order
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=order_db
DB_PORT=3306

# Phải trùng với JWT_ACCESS_SECRET của Auth Service — Order Service không phát hành token,
# chỉ XÁC THỰC chữ ký của Access Token do Auth Service ký.
JWT_ACCESS_SECRET=change_me_access_secret

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=order-service
KAFKA_CONSUMER_GROUP_ID=order-service-group

# Base URL nội bộ (trong mạng Docker) của Warehouse Service — Order Service gọi sang đồng bộ
# để giữ chỗ (lock) / nhả chỗ (release) / trừ kho (deduct) tồn kho khi xử lý vòng đời đơn hàng.
WAREHOUSE_SERVICE_URL=http://warehouse-service:3001

# Phí vận chuyển mặc định (đồng) — tạm thời cố định cho tới khi Shipping Service ra đời
# và cung cấp API tính phí thực tế theo địa chỉ/khối lượng.
DEFAULT_SHIPPING_FEE=30000
