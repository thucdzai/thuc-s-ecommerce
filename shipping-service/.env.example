PORT=3001

DB_HOST=mysql-shipping
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=shipping_db
DB_PORT=3306

# Phải trùng với JWT_ACCESS_SECRET của Auth Service — Shipping Service không phát hành token,
# chỉ XÁC THỰC chữ ký của Access Token do Auth Service ký (và token hệ thống do Order Service tự ký
# khi gọi nội bộ — xem order-service/src/utils/systemToken.js).
JWT_ACCESS_SECRET=change_me_access_secret

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=shipping-service
KAFKA_CONSUMER_GROUP_ID=shipping-service-group

# --- Cấu hình tính phí vận chuyển (mock GHTK/GHN) ---
# Không tích hợp API thật của đơn vị vận chuyển nào — đây là công thức tính phí giả lập
# (phí cơ bản + phụ phí theo cân nặng + phụ phí theo khu vực) để hệ thống tự vận hành khép kín,
# nhưng vẫn theo đúng cấu trúc input/output mà 1 API thật (GHTK/GHN) sẽ trả về.
SHIPPING_BASE_FEE=16500
SHIPPING_INNER_ZONE_KEYWORDS=Hồ Chí Minh,TP.HCM,TP HCM,Ho Chi Minh,HCM
