PORT=3001

DB_HOST=mysql-warehouse
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=warehouse_db
DB_PORT=3306

# Phải trùng với JWT_ACCESS_SECRET của Auth Service — Warehouse Service chỉ XÁC THỰC token
# (không tự phát hành), nên cần dùng chung secret để verify chữ ký JWT do Auth Service ký.
JWT_ACCESS_SECRET=change_me_access_secret

# Số phút giữ chỗ tồn kho khi khách đặt hàng — hết thời gian này mà chưa thanh toán thì tự nhả lại.
STOCK_LOCK_TTL_MINUTES=15

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=warehouse-service
KAFKA_CONSUMER_GROUP_ID=warehouse-service-group
