PORT=3001

DB_HOST=mysql-cart
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=cart_db
DB_PORT=3306

# Phải trùng với JWT_ACCESS_SECRET của Auth Service — Cart Service không phát hành token,
# chỉ XÁC THỰC chữ ký của Access Token do Auth Service ký (giỏ hàng luôn gắn với người dùng đã đăng nhập).
JWT_ACCESS_SECRET=change_me_access_secret

# Số lượng tối đa cho phép của 1 SKU trong giỏ hàng — chặn việc cộng dồn vô tội vạ qua API.
MAX_QUANTITY_PER_ITEM=100

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=cart-service
KAFKA_CONSUMER_GROUP_ID=cart-service-group
